# Clé API ElevenLabs (npm run tts)
ELEVENLABS_API_KEY=

# Chemin vers un Chrome/Chromium déjà installé sur la machine (ex: /usr/bin/google-chrome-stable).
# Laisser vide ou mettre "false" pour laisser Remotion télécharger et gérer
# lui-même son propre Chromium headless (comportement par défaut recommandé).
CHROME_EXECUTABLE_PATH=false

# Région AWS pour npm run render:lambda (voir src/render-lambda.ts)
REMOTION_AWS_REGION=eu-west-3
